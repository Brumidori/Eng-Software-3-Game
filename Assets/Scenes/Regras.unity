  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u2022 Cada jogador pode usar no m\xE1ximo 1 Power-Up por partida, sem
    repeti\xE7\xE3o. \n\u2022 O Power-Up deve ser acionado durante a janela de 4
    segundos de exibi\xE7\xE3o do tema , antes da pergunta aparecer.\n\u2022 Se o
    jogador n\xE3o acionar o Power-Up nessa janela, ele n\xE3o poder\xE1 ser usado
    naquela rodada.\n\u2022 Os Power-Ups s\xE3o consum\xEDveis: ao ser usado, ele
    \xE9 retirado do invent\xE1rio do jogador.\n\u2022 Os Power-Ups n\xE3o utilizados
    permanecem no invent\xE1rio indefinidamente.\n"
